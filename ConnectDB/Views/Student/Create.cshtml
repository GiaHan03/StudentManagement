@model ConnectDB.Models.Student

<h2>Thêm sinh viên</h2>

<form method="post">
    <div>
        Mã SV: <input asp-for="StudentCode" />
    </div>
    <div>
        Họ tên: <input asp-for="FullName" />
    </div>
    <div>
        Ngày sinh: <input asp-for="Birthday" type="date" />
    </div>
    <button type="submit">Lưu</button>
</form>