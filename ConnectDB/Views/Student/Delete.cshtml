@model ConnectDB.Models.Student

<h2>Xóa sinh viên</h2>

<p>Bạn có chắc muốn xóa sinh viên này không?</p>

<p><strong>Mã SV:</strong> @Model.StudentCode</p>
<p><strong>Họ tên:</strong> @Model.FullName</p>

<form method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit">Xóa</button>
</form>

<a href="/Student">Hủy</a>