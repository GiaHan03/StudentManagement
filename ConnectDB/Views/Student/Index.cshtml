@model List<ConnectDB.Models.Student>

<h2>Danh sách sinh viên</h2>

<a href="/Student/Create">Thêm mới</a>

<table border="1">
    <tr>
        <th>Mã SV</th>
        <th>Họ tên</th>
        <th>Ngày sinh</th>
        <th>Hành động</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.StudentCode</td>
            <td>@item.FullName</td>
            <td>@item.Birthday.ToShortDateString()</td>
            <td>
                <a href="/Student/Details/@item.Id">Xem</a> |
                <a href="/Student/Edit/@item.Id">Sửa</a> |
                <a href="/Student/Delete/@item.Id">Xóa</a>
            </td>
        </tr>
    }
</table>